{
  "install": [
    "chmod +x setup_cursor_background_agent_env.sh",
    "./setup_cursor_background_agent_env.sh"
  ],
  "terminals": [
    {
      "name": "drsearch_backend",
      "command": "cd drsearch_backend && poetry run uvicorn app.main:app --reload",
      "autostart": false
    },
    {
      "name": "drsearch_frontend",
      "command": "cd drsearch_frontend && yarn dev",
      "autostart": false
    }
  ]
} 
