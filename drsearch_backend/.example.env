# #set to false to disable Entra ID Auth
AUTH_ENABLED=False
# #set to false to disable Entra ID Auth
NEXT_PUBLIC_AUTH_ENABLED=False

#: Toggle RAG vs. plain-chatbot mode
RAG_ON=FALSE

CORS_ORIGINS=["http://DRSearch_frontend:3000","http://localhost:3000"]
# WHITELIST=["/chat/playground","/favicon.ico","/index-options"]


AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDER=your-embedding-deployment-name

# -------------------- OpenAI (public) --------------------
OPENAI_API_KEY=secret

# Chat & Embedding models are optional – sensible defaults are used when omitted
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -------------------- Service selection --------------------
# If both Azure and OpenAI credentials are present, set *LLM_SERVICE* to either
# 'azure' or 'openai' to control which backend is used. Default is 'azure'.
LLM_SERVICE=openai



# Azure AD Application (Client) ID for Backend
AZURE_AD_CLIENT_ID=secret

# Azure AD Tenant ID (shared across frontend and backend)
AZURE_AD_TENANT_ID=secret

# Azure AD Secret Value for Backend
AZURE_AD_CLIENT_SECRET=secret


WEAVIATE_URL=http://weaviate:8080
WEAVIATE_API_KEY=key
RECORD_MANAGER_DB_URL=postgresql://username:yourpassword@postgres_drsearch:5432/recordmanager_db