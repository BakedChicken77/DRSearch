# #set to false to disable Entra ID Auth
AUTH_ENABLED=False
# #set to false to disable Entra ID Auth
NEXT_PUBLIC_AUTH_ENABLED=False

#: Toggle RAG vs. plain-chatbot mode
RAG_ON=FALSE

LANGFUSE_ENABLED=False
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_SECRET_KEY=your-secret-key

CORS_ORIGINS=["http://DRSearch_frontend:3000","http://localhost:3000"]
# WHITELIST=["/chat/playground","/favicon.ico","/index-options"]

AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_ENDPOINT=your-endpoint-url
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_EMBEDDER=your-embedding-deployment-name

# -------------------- OpenAI (public) --------------------
OPENAI_API_KEY=secret

# Chat & Embedding models are optional – sensible defaults are used when omitted
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# -------------------- Service selection --------------------
# If both Azure and OpenAI credentials are present, set *LLM_SERVICE* to either
# 'azure' or 'openai' to control which backend is used. Default is 'azure'.
LLM_SERVICE=openai



# Azure AD Application (Client) ID for Backend
AZURE_AD_CLIENT_ID=secret

# Azure AD Tenant ID (shared across frontend and backend)
AZURE_AD_TENANT_ID=secret

# Azure AD Secret Value for Backend
AZURE_AD_CLIENT_SECRET=secret


WEAVIATE_URL=http://weaviate:8080
WEAVIATE_API_KEY=key

#location of the weaviate database schema. This is used by the transfer_weaviate_to_pgvector.py script
WEAVIATE_SCHEMA_FILE=scripts/weaviate_schema.json

RECORD_MANAGER_DB_URL=postgresql://username:yourpassword@postgres_drsearch:5432/recordmanager_db

# Vector database backend: "weaviate" or "pgvector"
VECTOR_BACKEND=weaviate
# PostgreSQL connection string used when VECTOR_BACKEND=pgvector
PGVECTOR_URL=postgresql://username:password@postgres_drsearch:5432/pgvector_db

# Azure Search connection settings used when VECTOR_BACKEND=azure
AZURE_SEARCH_ENDPOINT=https://your-search-resource.search.windows.net
AZURE_SEARCH_KEY=your-api-key

AZURE_SEARCH_INDEX=drsearch-index-test
AZURE_VECTOR_DIMENSION=1536

# Logging configuration
AZURE_STORAGE_CONNECTION_STRING=enter-blob-storage-connection-string
#LOG_OUTPUT_MODE can be set to local, blob, or both
LOG_OUTPUT_MODE=local
LOG_LEVEL=INFO
LOG_FILE_MAX_MB=20
LOG_BACKUP_COUNT=10
LOG_TO_BLOB_CONTAINER=drsearch-logs
BLOB_UPLOAD_INTERVAL_SEC=300
