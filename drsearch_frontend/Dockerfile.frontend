# COPY --from=stage1 /app/package.json ./package.json

# ##############
# ### Use second stage for production only. Comment out for development
# ##############


ENV NODE_ENV=production
ENV SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt




### UNCOMMENT TO ADD CA CERTIFICATES
# # ─── copy raw files ───────────────────────────────────────────────────────────
# COPY CA_certificates/ /usr/local/share/ca-certificates/

# # ─── normalise → install → bundle ────────────────────────────────────────────
# RUN set -e \
#  # 1) make sure all files have .crt so update-ca-certificates can see them
#  && find /usr/local/share/ca-certificates -type f \
#       \( -iname '*.pem' -o -iname '*.cer' \) \
#       -exec sh -c 'cp "$0" "${0%.*}.crt"' {} \; \
#  \
#  # 2) update the Debian/Ubuntu system trust store
#  && update-ca-certificates \
#  \
#  # 3) concatenate every CA into a single PEM                   (order unimportant)
#  && cat /usr/local/share/ca-certificates/*.crt > /etc/ssl/certs/extra-cas.pem




# 4) tell Node to use the bundle
ENV NODE_EXTRA_CA_CERTS=/etc/ssl/certs/extra-cas.pem


EXPOSE 3000

CMD ["yarn", "dev"]
