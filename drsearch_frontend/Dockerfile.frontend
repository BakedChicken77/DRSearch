
# Stage 1: Build frontend with Node.js
FROM node:20.10-buster AS stage1

WORKDIR /app

ENV NODE_ENV=development
# copy only what we need to install+build
# COPY package.json yarn.lock ./
COPY package.json ./

# Set npm registry for yarn and install frontend dependencies
RUN echo 'registry "https://registry.npmjs.org/"' > /app/.yarnrc && \
    yarn install

COPY . ./

# **NEW** build next.js for production
ENV NODE_ENV=production
RUN yarn build



# ##############
# ### Use second stage for production only. Comment out for development
# ##############
