event: data
data: {"ops":[{"op":"add","path":"/logs/AzureChatOpenAI:2/final_output","value":{"generations":[[{"text":"Component questions:\n1. What tools or libraries can be used to test a FastAPI server?\n2. How do I write unit tests for a FastAPI server?\n3. How do I write integration tests for a FastAPI server?\n4. What are the best practices for testing a FastAPI server?\n5. Are there any examples or tutorials for testing a FastAPI server?\n\nAlternative questions:\n1. What are the steps to test a FastAPI server?\n2. What are the recommended tools for testing a FastAPI application?\n3. How do I perform unit testing on a FastAPI server?\n4. How do I perform integration testing on a FastAPI server?\n5. Can you provide a guide or example for testing a FastAPI server?","generation_info":{"finish_reason":"stop"},"type":"ChatGeneration","message":{"content":"Component questions:\n1. What tools or libraries can be used to test a FastAPI server?\n2. How do I write unit tests for a FastAPI server?\n3. How do I write integration tests for a FastAPI server?\n4. What are the best practices for testing a FastAPI server?\n5. Are there any examples or tutorials for testing a FastAPI server?\n\nAlternative questions:\n1. What are the steps to test a FastAPI server?\n2. What are the recommended tools for testing a FastAPI application?\n3. How do I perform unit testing on a FastAPI server?\n4. How do I perform integration testing on a FastAPI server?\n5. Can you provide a guide or example for testing a FastAPI server?","additional_kwargs":{},"response_metadata":{"finish_reason":"stop"},"type":"ai","name":null,"id":"run-c7d04456-ea91-4450-99a1-cb271e0b1e50","example":false,"tool_calls":[],"invalid_tool_calls":[]}}]],"llm_output":null,"run":null}},{"op":"add","path":"/logs/AzureChatOpenAI:2/end_time","value":"2025-06-24T15:09:34.962+00:00"}]}

